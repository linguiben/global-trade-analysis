# web
PORT=9000
BASE_PATH=/gta
TZ=Asia/Shanghai

# Insight LLM (optional)
INSIGHT_LLM_PROVIDER=openai
INSIGHT_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
GEMINI_API_KEY=

# PostgreSQL (docker-compose)
POSTGRES_DB=gta
POSTGRES_USER=gta
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_PORT=9527
DATABASE_URL=postgresql+psycopg://gta:CHANGE_ME@db:5432/gta

# Remote server
REMOTE=REMOTE_USER@REMOTE_HOST
